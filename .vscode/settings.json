{
  "deno.enable": true,
  "deno.unstable": true,
  "[typescript]": {
    "editor.defaultFormatter": "denoland.vscode-deno",
    "editor.formatOnSave": true
  },
  "[json]": {
    "editor.defaultFormatter": "denoland.vscode-deno"
  },
  "deno.importMap": "./deno.json",
  "editor.codeActionsOnSave": {
    "source.fixAll.ts": true
  }
}
